# Supabase Configuration
# Get these from your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API URLs (only TOOL_POOL_API_URL and ATENDENTE_CORE are still used)
VITE_TOOL_POOL_API_URL=http://localhost:8006
VITE_ATENDENTE_CORE=http://localhost:8003
VITE_STANDALONE_AGENT_API=http://localhost:8001

# DEPRECATED - These APIs are no longer used (migrated to Supabase RPCs)
# VITE_API_URL_ANALYTICS=http://localhost:8004  # Use Supabase PostgREST instead
# VITE_DATA_INGESTION_API_URL=http://localhost:8008  # Use Supabase RPCs instead

# Grafana Faro — Frontend Observability (errors, web-vitals, traces)
# Uses the same OTLP gateway as the backend services (no separate Faro collector needed)
VITE_GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-sa-east-1.grafana.net/otlp
VITE_GRAFANA_OTLP_BASIC_AUTH=base64(instanceId:apiToken)
VITE_FARO_APP_NAME=vizu-dashboard

