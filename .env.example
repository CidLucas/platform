# Copy this file to .env and fill secrets/values before running services.
# Do NOT commit real secrets. Use your secret manager or CI secrets.

# Database
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>
TEST_DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5433/<TEST_DB>

# Supabase
SUPABASE_URL=https://<your-supabase>.supabase.co
SUPABASE_KEY=<supabase_public_key>
SUPABASE_SERVICE_KEY=<supabase_service_key>
SUPABASE_DB_URL=postgresql://<user>:<password>@<host>:5432/postgres
SUPABASE_DB_PASSWORD=<supabase_db_password>
SUPABASE_JWT_SECRET=<supabase_jwt_secret>

# Redis (optional - services should handle missing Redis gracefully)
REDIS_URL=redis://localhost:6379/0

# Vector DB
QDRANT_URL=<qdrant_cloud_url>
QDRANT_API_KEY=<qdrant_api_key>

# Encryption / Credentials
CREDENTIALS_ENCRYPTION_KEY=<fernet_key_base64>

# LLM Providers
LLM_PROVIDER=google
OPENAI_API_KEY=<openai_api_key>
ANTHROPIC_API_KEY=<anthropic_api_key>
GOOGLE_API_KEY=<google_api_key>

# Observability - Langfuse (LLM tracing)
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=<langfuse_public_key>
LANGFUSE_SECRET_KEY=<langfuse_secret_key>

# Observability - Grafana Cloud (OTLP)
# For local dev, you can point to a local OTEL collector or leave empty
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-sa-east-1.grafana.net/otlp
# Format: "Authorization=Basic <base64(instanceId:apiKey)>"
OTEL_EXPORTER_OTLP_HEADERS=<grafana_otlp_auth_header>

# OAuth / Auth
MCP_AUTH_GOOGLE_CLIENT_ID=<google_client_id>
MCP_AUTH_GOOGLE_CLIENT_SECRET=<google_client_secret>

# Misc
LANGCHAIN_API_KEY=<langchain_api_key>
