# .env.example - Copie para .env e preencha com seus valores locais.
# NUNCA comite o arquivo .env no repositório.

# Ambiente de execução: development, staging, ou production
ENVIRONMENT="development"

# ============================================================================
# SUPABASE (PREFERENCIAL - usa API REST, não conexão direta PostgreSQL)
# ============================================================================
# API URL do projeto Supabase (não é connection string!)
SUPABASE_URL="https://haruewffnubdgyofftut.supabase.co"

# Service Role Key (para operações server-side, bypassa RLS quando necessário)
# Encontre em: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# (Opcional) Anon Key para operações client-side com RLS enforcement
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ============================================================================
# DATABASE (LEGADO - usado apenas para migrations via Alembic e SQL Agent)
# ============================================================================
# Para desenvolvimento local:
DATABASE_URL="postgresql://user:password@postgres:5432/vizu_db"

# Para Supabase (se precisar rodar migrations diretamente):
# SUPABASE_DB_URL="postgresql://postgres.xxxxx:password@host:5432/postgres"

# ============================================================================
# LLM PROVIDER (ollama_cloud, openai, anthropic, google)
# ============================================================================
LLM_PROVIDER="ollama_cloud"

# Ollama Cloud (https://ollama.com/settings/keys)
OLLAMA_CLOUD_API_KEY="your-api-key"
OLLAMA_CLOUD_BASE_URL="https://ollama.com"

# Embedding Service (local)
EMBEDDING_SERVICE_URL="http://embedding_service:11435"

# ============================================================================
# LLM APIs COMERCIAIS (optional - use if LLM_PROVIDER != ollama_cloud)
# ============================================================================
# OpenAI
OPENAI_API_KEY=""

# Anthropic (Claude)
ANTHROPIC_API_KEY=""

# Google Gemini
GOOGLE_API_KEY=""

# ============================================================================
# LANGFUSE (Observabilidade/Tracing)
# ============================================================================
# Crie conta gratuita em: https://cloud.langfuse.com
LANGFUSE_HOST="https://cloud.langfuse.com"
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_SECRET_KEY="sk-lf-..."

# ============================================================================
# OUTROS SERVIÇOS
# ============================================================================
# LangChain/LangSmith (alternativa ao Langfuse)
LANGCHAIN_API_KEY=""

# Conexão com Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_URL="redis://redis:6379/0"

# Twilio
TWILIO_AUTH_TOKEN=""