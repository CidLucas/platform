# --- Configuração do Ambiente ---
VIZU_ENV="development"

# --- Conexões de Infraestrutura ---
# O tool_pool_api usa o context_service, que precisa do DB Vizu e do Redis.

# URL do banco de dados principal da Vizu
DATABASE_URL="postgresql+asyncpg://admin:admin@postgres:5432/vizu_db"

# URL do Redis para cache de contexto
REDIS_URL="redis://redis:6379/0"

# --- Observabilidade ---
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector:4317"