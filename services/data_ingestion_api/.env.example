# Data Ingestion API Configuration

# Service Name
SERVICE_NAME=Vizu Data Ingestion API

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=

# CORS Configuration
# Lista de origens permitidas separadas por vírgula
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://app.vizu.com.br

# Em desenvolvimento, pode permitir todas as origens (usar com cuidado!)
# CORS_ALLOW_ALL=true

# Supabase Configuration
SUPABASE_URL=your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Google Cloud (se necessário)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id
