# .env.example - Copie para .env e preencha com seus valores locais.
# NUNCA comite o arquivo .env no repositório.

# Ambiente de execução: development, staging, ou production
ENVIRONMENT="development"

# Chaves da LangChain para observabilidade
LANGCHAIN_API_KEY="sua_chave_langsmith_aqui"

# URL do serviço que gerencia os clientes e suas credenciais
CLIENTS_API_URL="http://localhost:8001/api/v1"

# Conexão com Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"