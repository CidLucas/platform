# =============================================================================
# VIZU PRODUCTION ENVIRONMENT
# =============================================================================
# ⚠️ SECURITY WARNING: This file contains REAL secrets.
#    - NEVER commit to git
#    - For Cloud Run: Store in Google Secret Manager (gcloud secrets create)
#    - For DigitalOcean: chmod 600 .env.production on droplet
#    - Store backups securely (password manager, encrypted storage)
#
# CLOUD RUN: These env vars are loaded via --set-secrets in deployment workflow
# See: docs/operations/CLOUD_RUN_DEPLOYMENT.md
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub Container Registry (GHCR)
# -----------------------------------------------------------------------------
USE_GHCR=true
GHCR_OWNER=vizubr
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Domain & Environment
# -----------------------------------------------------------------------------
DOMAIN=api.yourdomain.com
ENVIRONMENT=production
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (Supabase)
# -----------------------------------------------------------------------------
# Project ref from your setup: haruewffnubdgyofftut
# Get connection details from: https://app.supabase.com/project/haruewffnubdgyofftut/settings/database
DATABASE_URL=postgresql://postgres.haruewffnubdgyofftut:[YOUR-DB-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://haruewffnubdgyofftut.supabase.co
SUPABASE_KEY=[YOUR-SUPABASE-ANON-KEY]
SUPABASE_SERVICE_KEY=[YOUR-SUPABASE-SERVICE-KEY]
SUPABASE_JWT_SECRET=[YOUR-SUPABASE-JWT-SECRET]

DB_MODE=supabase
USE_LOCAL_DB=false

# -----------------------------------------------------------------------------
# Redis (required for atendente_core, tool_pool_api)
# -----------------------------------------------------------------------------
# For Cloud Run: Use Redis Cloud or Upstash
# Get from: https://app.redislabs.com or https://console.upstash.com
REDIS_URL=redis://default:[YOUR-REDIS-PASSWORD]@[YOUR-REDIS-HOST]:6379

# -----------------------------------------------------------------------------
# Vector Database (Qdrant Cloud)
# -----------------------------------------------------------------------------
# Your cluster URL (from conversation)
QDRANT_URL=https://[YOUR-QDRANT-CLUSTER].sa-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=[YOUR-QDRANT-API-KEY]

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
LLM_PROVIDER=google

# Google AI (Gemini) - https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=[YOUR-GOOGLE-API-KEY]

# OpenAI (optional) - https://platform.openai.com/account/api-keys
OPENAI_API_KEY=

# Anthropic (optional) - https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# Ollama (for local/cloud LLM)
# Leave empty for production (we use Google/OpenAI)
OLLAMA_BASE_URL=

# -----------------------------------------------------------------------------
# Observability - OpenTelemetry to Grafana Cloud
# -----------------------------------------------------------------------------
# Grafana Cloud OTLP Gateway (São Paulo region)
# Get from: Grafana Cloud → Connections → OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-sa-east-1.grafana.net/otlp
OTEL_SERVICE_NAME=vizu-prod
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.namespace=vizu

# Authorization: Base64 encode "INSTANCE_ID:API_TOKEN"
# Command: echo -n "YOUR_INSTANCE_ID:YOUR_API_TOKEN" | base64
# Then format as: Authorization=Basic BASE64_RESULT
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic [YOUR-BASE64-ENCODED-CREDENTIALS]"

# -----------------------------------------------------------------------------
# Observability - Langfuse (LLM Tracing)
# -----------------------------------------------------------------------------
# Get from: https://us.cloud.langfuse.com → Settings → API Keys
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=[YOUR-LANGFUSE-PUBLIC-KEY]
LANGFUSE_SECRET_KEY=[YOUR-LANGFUSE-SECRET-KEY]

# -----------------------------------------------------------------------------
# Google OAuth (for MCP Google integrations)
# -----------------------------------------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID → Web application
# Authorized redirect URI: https://YOUR_DOMAIN/mcp/auth/callback
MCP_AUTH_GOOGLE_CLIENT_ID=[YOUR-GOOGLE-OAUTH-CLIENT-ID].apps.googleusercontent.com
MCP_AUTH_GOOGLE_CLIENT_SECRET_DEV=[YOUR-GOOGLE-CLIENT-SECRET]
MCP_AUTH_BASE_URL=https://api.yourdomain.com

# -----------------------------------------------------------------------------
# Security & Encryption
# -----------------------------------------------------------------------------
# ⚠️ CRITICAL: This key encrypts user credentials in the database
# Generated with: python -c "import secrets; print(secrets.token_hex(32))"
# DO NOT lose this key - you won't be able to decrypt existing credentials
CREDENTIALS_ENCRYPTION_KEY=[YOUR-ENCRYPTION-KEY-64-HEX-CHARS]

# -----------------------------------------------------------------------------
# Embedding Service
# -----------------------------------------------------------------------------
# Production: smaller, faster model
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_VECTOR_SIZE=384
EMBEDDING_MODEL_DEVICE=cpu
EMBEDDING_SERVICE_URL=http://embedding_service:11435

# -----------------------------------------------------------------------------
# External Integrations (optional)
# -----------------------------------------------------------------------------
# Twilio (SMS/WhatsApp)
TWILIO_AUTH_TOKEN=

# LangChain
LANGCHAIN_API_KEY=

# SendGrid (email)
SENDGRID_API_KEY=
