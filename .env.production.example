# =============================================================================
# PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# DO NOT commit real values. All secrets must come from Google Secret Manager.
# This file documents which environment variables each service expects.
#
# Secret Manager naming convention:
#   projects/<PROJECT_ID>/secrets/<SECRET_NAME>/versions/latest
#
# Cloud Run will inject these at deploy time via --set-secrets flag.
# =============================================================================

# -----------------------------------------------------------------------------
# GCP Project Configuration
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=<your-gcp-project-id>
GCP_REGION=us-central1

# -----------------------------------------------------------------------------
# Database (Supabase or Cloud SQL)
# -----------------------------------------------------------------------------
# Secret: DATABASE_URL
# Format: postgresql://<user>:<password>@<host>:5432/<db>?sslmode=require
DATABASE_URL=sm://DATABASE_URL

# Supabase-specific (if using Supabase)
SUPABASE_URL=sm://SUPABASE_URL
SUPABASE_KEY=sm://SUPABASE_KEY
SUPABASE_SERVICE_KEY=sm://SUPABASE_SERVICE_KEY
SUPABASE_JWT_SECRET=sm://SUPABASE_JWT_SECRET

# -----------------------------------------------------------------------------
# Redis (Cloud Memorystore or Upstash)
# -----------------------------------------------------------------------------
REDIS_URL=sm://REDIS_URL

# -----------------------------------------------------------------------------
# Vector DB (Qdrant Cloud)
# -----------------------------------------------------------------------------
QDRANT_URL=sm://QDRANT_URL
QDRANT_API_KEY=sm://QDRANT_API_KEY

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
LLM_PROVIDER=google
# OpenAI
OPENAI_API_KEY=sm://OPENAI_API_KEY
# Anthropic
ANTHROPIC_API_KEY=sm://ANTHROPIC_API_KEY
# Google Vertex AI / Gemini
GOOGLE_API_KEY=sm://GOOGLE_API_KEY
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-credentials.json

# -----------------------------------------------------------------------------
# Observability - Langfuse
# -----------------------------------------------------------------------------
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=sm://LANGFUSE_PUBLIC_KEY
LANGFUSE_SECRET_KEY=sm://LANGFUSE_SECRET_KEY

# -----------------------------------------------------------------------------
# Observability - Datadog
# -----------------------------------------------------------------------------
DD_API_KEY=sm://DD_API_KEY
DD_SITE=datadoghq.com
DD_ENV=production
DD_SERVICE=vizu
DD_VERSION=${COMMIT_SHA:-unknown}
DD_LOGS_INJECTION=true
DD_TRACE_ENABLED=true
DD_PROFILING_ENABLED=true

# -----------------------------------------------------------------------------
# OpenTelemetry (forwarded to Datadog via OTEL Collector or direct)
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.datadoghq.com
OTEL_EXPORTER_OTLP_HEADERS=DD-API-KEY=${DD_API_KEY}
OTEL_SERVICE_NAME=${DD_SERVICE}
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.version=${DD_VERSION}

# -----------------------------------------------------------------------------
# Encryption & Security
# -----------------------------------------------------------------------------
CREDENTIALS_ENCRYPTION_KEY=sm://CREDENTIALS_ENCRYPTION_KEY

# -----------------------------------------------------------------------------
# OAuth / External Auth
# -----------------------------------------------------------------------------
MCP_AUTH_GOOGLE_CLIENT_ID=sm://MCP_AUTH_GOOGLE_CLIENT_ID
MCP_AUTH_GOOGLE_CLIENT_SECRET=sm://MCP_AUTH_GOOGLE_CLIENT_SECRET

# -----------------------------------------------------------------------------
# External Integrations
# -----------------------------------------------------------------------------
TWILIO_AUTH_TOKEN=sm://TWILIO_AUTH_TOKEN
LANGCHAIN_API_KEY=sm://LANGCHAIN_API_KEY

# -----------------------------------------------------------------------------
# Runtime Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=production
USE_LOCAL_DB=false
