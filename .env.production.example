# =============================================================================
# PRODUCTION ENVIRONMENT - DigitalOcean Deployment
# =============================================================================
# Copy this to .env.production and fill in your actual values
# NEVER commit .env.production to git!
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase)
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=eyJ...  # anon/public key
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (keep secret!)
SUPABASE_JWT_SECRET=your-jwt-secret

# -----------------------------------------------------------------------------
# Vector DB (Qdrant Cloud)
# -----------------------------------------------------------------------------
# Get from Qdrant Cloud dashboard
QDRANT_URL=https://xxx-xxx-xxx.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
LLM_PROVIDER=google

# Google AI (Gemini)
GOOGLE_API_KEY=your-google-api-key

# OpenAI (optional, for fallback)
OPENAI_API_KEY=

# Anthropic (optional, for fallback)
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Observability - Langfuse (LLM tracing)
# -----------------------------------------------------------------------------
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# -----------------------------------------------------------------------------
# Observability - Grafana Cloud (OTLP)
# -----------------------------------------------------------------------------
# Your Grafana Cloud OTLP endpoint (São Paulo region)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-sa-east-1.grafana.net/otlp

# OTLP authentication header
# Format: Authorization=Basic <base64(instanceId:grafana_api_key)>
# To generate: echo -n "123456:glc_xxx..." | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic YOUR_BASE64_ENCODED_CREDENTIALS

OTEL_SERVICE_NAME=vizu-prod
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production

# -----------------------------------------------------------------------------
# Encryption & Security
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CREDENTIALS_ENCRYPTION_KEY=your-32-byte-hex-key

# -----------------------------------------------------------------------------
# OAuth / External Auth (optional)
# -----------------------------------------------------------------------------
MCP_AUTH_GOOGLE_CLIENT_ID=
MCP_AUTH_GOOGLE_CLIENT_SECRET_DEV=
MCP_AUTH_BASE_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# External Integrations (optional)
# -----------------------------------------------------------------------------
TWILIO_AUTH_TOKEN=
LANGCHAIN_API_KEY=

# -----------------------------------------------------------------------------
# Embedding Service
# -----------------------------------------------------------------------------
# Use smaller/faster model for production
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_VECTOR_SIZE=384
EMBEDDING_MODEL_DEVICE=cpu

# -----------------------------------------------------------------------------
# Domain Configuration (for Caddy HTTPS)
# -----------------------------------------------------------------------------
DOMAIN=api.yourdomain.com

# -----------------------------------------------------------------------------
# Runtime Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=production
USE_LOCAL_DB=false
DB_MODE=supabase
