                            "caminho"
                        ]
                    },
                    "aggregates": [
                        "COUNT",
                        "SUM"
                    ],
                    "max_rows": 5000,
                    "max_execution_time_seconds": 30,
                    "join_paths": []
                },
                "viewer": {
                    "views": [
                        "customers_view"
                    ],
                    "columns": {
                        "customers_view": [
                            "id",
