# Twilio Configuration
# Required: Your Twilio Account SID (starts with 'AC')
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: Your Twilio Auth Token
TWILIO_AUTH_TOKEN=your_auth_token_here

# Optional: Twilio Messaging Service SID (starts with 'MG')
# Use this if you want to send messages through a messaging service
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Default phone number for sending messages
# If not set, you must specify from_ parameter in send methods
# TWILIO_DEFAULT_FROM_NUMBER=+1234567890
