# --- ARQUIVO .ENV (PADRONIZADO) ---

# 1. SELEÇÃO DE AMBIENTE (Comente/Descomente para trocar)
# [A] MODO LOCAL (Docker) - Use este para desenvolver agora!
# DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>
# DB_MODE=postgres_local

# [B] MODO PRODUÇÃO (Supabase)
# Using connection pooler for better Docker compatibility
DATABASE_URL=postgresql+psycopg2://postgres.haruewffnubdgyofftut:tMz1us7KsAHQs6QT@aws-0-us-west-2.pooler.supabase.com:5432/postgres
DB_MODE=supabase_api

# Analytics API Database - Override for local development
# Uncomment for local postgres, comment for Supabase production
# ANALYTICS_DATABASE_URL=postgresql+psycopg2://user:password@postgres:5432/vizu_db

# 2. CONFIGURAÇÕES DO SUPABASE (Infraestrutura)
# Extraído do seu host: db.haruewffnubdgyofftut.supabase.co
SUPABASE_PROJECT_ID=<your-supabase-project-id>
SUPABASE_URL=https://<your-supabase>.supabase.co
SUPABASE_SERVICE_KEY=<supabase_service_key>
SUPABASE_DB_PASSWORD=<supabase_db_password>
SUPABASE_DB_URL=postgresql://<user>:<password>@<host>:5432/postgres
# JWT Configuration for ES256 (Elliptic Curve) - Supabase uses ECC P-256
JWT_ALGORITHM=ES256
SUPABASE_JWT_JWK={"x":"CkE9NcHtUGdG-jNw7n_fqj4cplx33BvosUScNtbGizU","y":"ScKTrvyOS3u9l5xMd2Bnc-qJMBUZe1tagH77m6vB1d8","alg":"ES256","crv":"P-256","ext":true,"kid":"e4231cf2-75a4-4846-b7f9-afcc2d71abd7","kty":"EC","key_ops":["verify"]}


# 3. INTEGRAÇÕES EXTERNAS
LANGCHAIN_API_KEY=<langchain_api_key>
TWILIO_AUTH_TOKEN=<twilio_auth_token>

# 4. GOOGLE CLOUD PLATFORM
GCP_PROJECT_ID=<your-gcp-project-id>
GCS_BUCKET_NAME=<your-gcs-bucket>
PUBSUB_TOPIC_ID=<your-pubsub-topic>
PUBSUB_SUBSCRIPTION_ID=<your-pubsub-subscription>
GRAFANA_API_KEY=<your-grafana-api-key>

# 5. SEGURANÇA INTERNA
CREDENTIALS_ENCRYPTION_KEY=<fernet_key_base64>
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-sa-east-1.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20Z2xjX2V5SnZJam9pTVRZeE16STNNeUlzSW00aU9pSmtaWFpmZG1sNmRTSXNJbXNpT2lJNGRqSTVPVmsxUm5OWk1IbzJNak5YVFZrelNITlhiR2tpTENKdElqcDdJbklpT2lKd2NtOWtMWE5oTFdWaGMzUXRNU0o5ZlE9PToxNDY0NDcz
# 6. PERFIL DO DOCKER COMPOSE
# Use "local" para subir o banco Postgres local. Use "production" para não subir.
COMPOSE_PROFILES=local

# 7. LLM E EMBEDDING
# Provider: ollama (local), ollama_cloud (ollama.com), openai, anthropic, google
LLM_PROVIDER=ollama_cloud
OLLAMA_BASE_URL=http://ollama_service:11434

# Ollama Cloud (https://ollama.com/settings/keys para API key)
# Ref: https://docs.ollama.com/cloud
OLLAMA_CLOUD_API_KEY=<ollama_cloud_api_key>
OLLAMA_CLOUD_BASE_URL=https://ollama.com
OLLAMA_CLOUD_DEFAULT_MODEL=gpt-oss:20b

# Embedding Service - Modelo multilingual de alta qualidade para PT-BR
# Opções: sentence-transformers/all-MiniLM-L6-v2 (384), intfloat/multilingual-e5-large (1024)
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large
EMBEDDING_VECTOR_SIZE=1024
EMBEDDING_MODEL_DEVICE=cpu
EMBEDDING_SERVICE_URL=http://embedding_service:11435

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_URL_PROD=https://5bea0e4c-6394-4da0-9e4b-6c0ae6a56830.sa-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=<qdrant_api_key>

# 8. Langfuse (Observabilidade LLM)
LANGFUSE_SECRET_KEY=<langfuse_secret_key>
LANGFUSE_PUBLIC_KEY=<langfuse_public_key>
LANGFUSE_HOST=http://host.docker.internal:3000

# Google OAuth config for tool_pool_api
MCP_AUTH_GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
MCP_AUTH_GOOGLE_CLIENT_SECRET_DEV=<google_client_secret_dev>
MCP_AUTH_BASE_URL=http://localhost:8006
CREDENTIALS_ENCRYPTION_KEY=<fernet_key_base64>

