# ===============================================
# VIZU Cloud Run Environment Variables
# Copy to .env.cloudrun and fill in values
# ===============================================

# GCP Configuration
GCP_PROJECT=vizudev
GCP_REGION=southamerica-east1
IMAGE_TAG=latest

# Supabase (Cloud)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWT_JWK=your-jwk-json
JWT_ALGORITHM=ES256
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Qdrant Cloud
QDRANT_URL=https://xxxx.qdrant.cloud
QDRANT_API_KEY=your-qdrant-api-key

# LLM Providers
LLM_PROVIDER=google
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse (Cloud)
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key

# Redis (required for context caching)
REDIS_URL=redis://your-redis-host:6379/0

# OpenTelemetry (Grafana Cloud - optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=vizu-cloudrun

# Inter-service URLs (set to Cloud Run URLs in production)
# For local testing, these use docker-compose networking
MCP_SERVER_URL=http://tool_pool_api:8000/mcp/
BASE_URL=http://atendente_core:8000
EMBEDDING_SERVICE_URL=http://embedding_service:11435

# Dashboard build-time vars
VITE_API_URL=http://localhost:8003
VITE_ATENDENTE_CORE=http://localhost:8003
# DEPRECATED: VITE_ANALYTICS_API removed - all analytics via Supabase PostgREST

# Tool Pool API (Google OAuth for MCP tools)
MCP_AUTH_GOOGLE_CLIENT_ID=
MCP_AUTH_GOOGLE_CLIENT_SECRET_DEV=
MCP_AUTH_BASE_URL=
CREDENTIALS_ENCRYPTION_KEY=
